# ─────────────────────────────────────────────
# IBM watsonx.ai Configuration
# ─────────────────────────────────────────────
WATSONX_API_KEY=your_watsonx_api_key
WATSONX_PROJECT_ID=your_watsonx_project_id
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ─────────────────────────────────────────────
# API Configuration
# ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
SECRET_KEY=change_this_to_a_long_random_secret

# ─────────────────────────────────────────────
# CORS — comma-separated list of allowed origins
# In production: set to your Vercel frontend URL
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─────────────────────────────────────────────
# Firebase Authentication
# Get service account JSON from Firebase Console >
# Project Settings > Service Accounts > Generate new private key
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
# Option A: path to the downloaded service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccountKey.json
# Option B: paste the entire JSON as a single-line string (recommended for cloud)
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─────────────────────────────────────────────
# Neo4j AuraDB
# Get these from your AuraDB instance dashboard
# ─────────────────────────────────────────────
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_auradb_password

# ─────────────────────────────────────────────
# Cloudflare R2 Storage
# 1. Go to Cloudflare Dashboard > R2 > Create bucket
# 2. Go to R2 > Manage R2 API Tokens > Create API Token
# 3. Copy Account ID from the R2 overview page
# ─────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=graphmind-uploads
# Optional: public URL if you've enabled public access on the bucket
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─────────────────────────────────────────────
# File Upload Settings
# ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=104857600
